<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_template_tree" model="ir.ui.view">
        <field name="name">mr.whatsapp.template.list</field>
        <field name="model">mr.whatsapp.template</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Templates">
                <field name="name"/>
                <field name="model_id"/>
                <field name="phone_field"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_template_form" model="ir.ui.view">
        <field name="name">mr.whatsapp.template.form</field>
        <field name="model">mr.whatsapp.template</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Sales order confirmation"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="phone_field" placeholder="mobile"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="report_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body" name="body">
                            <field name="body" placeholder="Hello {{ object.name }}, ..."/>
                            <div class="text-muted">
                                Use inline-template syntax. Example:
                                <code>Hi {{ object.partner_id.name }}, your order {{ object.name }} is ready.</code>
                            </div>
                        </page>
                        <page string="Static Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_template_search" model="ir.ui.view">
        <field name="name">mr.whatsapp.template.search</field>
        <field name="model">mr.whatsapp.template</field>
        <field name="arch" type="xml">
            <search string="Templates">
                <field name="name"/>
                <field name="model_id"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <group>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_template" model="ir.actions.act_window">
        <field name="name">WhatsApp Templates</field>
        <field name="res_model">mr.whatsapp.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
