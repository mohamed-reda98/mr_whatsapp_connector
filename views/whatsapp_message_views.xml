<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_message_tree" model="ir.ui.view">
        <field name="name">mr.whatsapp.message.list</field>
        <field name="model">mr.whatsapp.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages" decoration-danger="state == 'failed'"
                  decoration-success="state == 'sent' or state == 'delivered' or state == 'read'"
                  decoration-info="direction == 'in'">
                <field name="create_date" string="When"/>
                <field name="direction"/>
                <field name="number"/>
                <field name="partner_id" optional="show"/>
                <field name="message"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('sent','delivered','read','received')"
                       decoration-danger="state == 'failed'"/>
                <field name="user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_message_form" model="ir.ui.view">
        <field name="name">mr.whatsapp.message.form</field>
        <field name="model">mr.whatsapp.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message">
                <header>
                    <button name="action_resend" type="object" string="Resend"
                            class="btn-primary"
                            invisible="direction != 'out'"/>
                    <button name="action_open_source" type="object" string="Open Source"
                            invisible="not res_model or not res_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,delivered,read,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="direction"/>
                            <field name="number"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="sidecar_message_id"/>
                            <field name="sent_at"/>
                            <field name="received_at"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                    <group string="Error" invisible="not error">
                        <field name="error" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_message_search" model="ir.ui.view">
        <field name="name">mr.whatsapp.message.search</field>
        <field name="model">mr.whatsapp.message</field>
        <field name="arch" type="xml">
            <search string="Messages">
                <field name="number"/>
                <field name="partner_id"/>
                <field name="message"/>
                <filter string="Outgoing" name="out" domain="[('direction','=','out')]"/>
                <filter string="Incoming" name="incoming" domain="[('direction','=','in')]"/>
                <separator/>
                <filter string="Failed" name="failed" domain="[('state','=','failed')]"/>
                <filter string="Sent" name="sent" domain="[('state','in',['sent','delivered','read'])]"/>
                <group>
                    <filter string="Direction" name="group_direction" context="{'group_by': 'direction'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_message" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">mr.whatsapp.message</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
