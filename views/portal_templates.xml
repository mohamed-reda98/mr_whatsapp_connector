<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal Home: "Send WhatsApp Message" card entry -->
    <template id="portal_my_home_whatsapp" name="Portal My Home: Send WhatsApp"
              inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/mr_whatsapp_connector/static/src/img/whatsapp-portal.svg'"/>
                <t t-set="title">Send WhatsApp Message</t>
                <t t-set="text">Send messages and attachments via WhatsApp</t>
                <t t-set="url" t-value="'/whatsapp/send'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </xpath>
    </template>

    <!-- Portal: WhatsApp send form page -->
    <template id="portal_send_form" name="WhatsApp Portal Send Form">
        <t t-call="portal.portal_layout">

            <div class="container mt-4 mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-6 col-md-8">

                        <div class="card shadow-sm">

                            <div class="card-header d-flex align-items-center gap-2"
                                 style="background:#25D366;color:#fff;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                     viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                </svg>
                                <h5 class="mb-0 fw-semibold">Send WhatsApp Message</h5>
                            </div>

                            <div class="card-body p-4">

                                <t t-if="success">
                                    <div class="text-center py-4">
                                        <i class="fa fa-check-circle fa-3x text-success mb-3"/>
                                        <h5 class="fw-semibold text-success">Message Sent!</h5>
                                        <p class="text-muted mb-4">
                                            Your message was delivered to
                                            <strong><t t-esc="sent_to"/></strong>.
                                        </p>
                                        <a href="/whatsapp/send" class="btn btn-success px-4">
                                            Send Another
                                        </a>
                                    </div>
                                </t>

                                <t t-if="not success">

                                    <t t-if="error">
                                        <div class="alert alert-danger d-flex gap-2 align-items-start" role="alert">
                                            <i class="fa fa-exclamation-triangle mt-1"/>
                                            <span><strong>Error:</strong> <t t-esc="error"/></span>
                                        </div>
                                    </t>

                                    <form method="POST" action="/whatsapp/send"
                                          enctype="multipart/form-data" novalidate="novalidate">

                                        <div class="mb-3">
                                            <label for="wa_number" class="form-label fw-semibold">
                                                Recipient phone number
                                                <span class="text-danger">*</span>
                                            </label>
                                            <input
                                                type="tel"
                                                id="wa_number"
                                                name="number"
                                                class="form-control"
                                                placeholder="+20 123 456 7890"
                                                t-att-value="number or ''"
                                                required="required"
                                                autocomplete="tel"
                                            />
                                            <div class="form-text">
                                                Include the country code, e.g. +1 for USA or +20 for Egypt.
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="wa_message" class="form-label fw-semibold">
                                                Message
                                            </label>
                                            <textarea
                                                id="wa_message"
                                                name="message"
                                                class="form-control"
                                                rows="5"
                                                placeholder="Type your message here…"
                                            ><t t-esc="message or ''"/></textarea>
                                        </div>

                                        <div class="mb-4">
                                            <label for="wa_attachments" class="form-label fw-semibold">
                                                Attachments
                                            </label>
                                            <input
                                                type="file"
                                                id="wa_attachments"
                                                name="attachments"
                                                class="form-control"
                                                multiple="multiple"
                                            />
                                            <div class="form-text">
                                                Images, PDFs, documents — any file WhatsApp supports.
                                            </div>
                                        </div>

                                        <div class="d-grid">
                                            <button type="submit" class="btn btn-success btn-lg">
                                                <i class="fa fa-paper-plane me-2"/>
                                                Send via WhatsApp
                                            </button>
                                        </div>

                                    </form>
                                </t>

                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </t>
    </template>

</odoo>
