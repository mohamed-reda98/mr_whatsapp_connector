<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_whatsapp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.whatsapp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="WhatsApp" string="WhatsApp" name="mr_whatsapp_connector"
                     groups="base.group_system">
                    <block title="Sidecar Connection" id="mr_whatsapp_sidecar">
                        <setting id="mr_whatsapp_sidecar_url"
                                 string="Sidecar URL"
                                 help="Base URL of the Node.js whatsapp-web.js service.">
                            <field name="whatsapp_sidecar_url" placeholder="http://localhost:3000"/>
                        </setting>
                        <setting id="mr_whatsapp_api_key"
                                 string="API Key"
                                 help="Shared secret matching the sidecar's SIDECAR_API_KEY.">
                            <field name="whatsapp_api_key" password="True"/>
                        </setting>
                        <setting id="mr_whatsapp_country"
                                 string="Default Country Code"
                                 help="Used to prefix local phone numbers (digits only, e.g. 20).">
                            <field name="whatsapp_default_country_code" placeholder="20"/>
                        </setting>
                        <setting id="mr_whatsapp_log_incoming"
                                 string="Log Incoming Messages"
                                 help="Store messages received via the sidecar webhook.">
                            <field name="whatsapp_log_incoming"/>
                        </setting>
                    </block>

                    <block title="Pairing" id="mr_whatsapp_pairing">
                        <setting id="mr_whatsapp_qr"
                                 string="QR Pairing"
                                 help="Open WhatsApp on your phone, go to Linked Devices, then scan the QR code below.">
                            <div class="o_mr_whatsapp_qr_block">
                                <field name="whatsapp_status_state" widget="mr_whatsapp_qr"/>
                            </div>
                        </setting>
                        <setting id="mr_whatsapp_actions"
                                 string="Session Controls">
                            <div>
                                <button name="action_whatsapp_refresh" type="object"
                                        string="Refresh" class="btn-secondary me-1"/>
                                <button name="action_whatsapp_logout" type="object"
                                        string="Logout / Unpair" class="btn-warning"
                                        confirm="This will unpair the WhatsApp session. Continue?"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_whatsapp_settings" model="ir.actions.act_window">
        <field name="name">WhatsApp Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'mr_whatsapp_connector'}</field>
    </record>
</odoo>
