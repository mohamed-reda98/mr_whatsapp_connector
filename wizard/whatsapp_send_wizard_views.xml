<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_send_wizard_form" model="ir.ui.view">
        <field name="name">mr.whatsapp.send.wizard.form</field>
        <field name="model">mr.whatsapp.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Send WhatsApp Message">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1" force_save="1" invisible="not partner_id"/>
                            <field name="number" placeholder="+20 100 000 0000"/>
                            <field name="country_code" placeholder="20"/>
                        </group>
                        <group>
                            <field name="log_to_chatter"/>
                            <field name="res_model" invisible="1"/>
                            <field name="res_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1" placeholder="Type your WhatsApp message..."/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send" type="object" string="Send" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_whatsapp_send_wizard" model="ir.actions.act_window">
        <field name="name">Send WhatsApp Message</field>
        <field name="res_model">mr.whatsapp.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
